#!/bin/sh
# Maven Wrapper script for Linux/Mac
MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
    echo "Downloading Maven wrapper..."
    mkdir -p .mvn/wrapper
    curl -s https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar -o "$MAVEN_WRAPPER_JAR" 2>/dev/null || \
    wget -q https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar -O "$MAVEN_WRAPPER_JAR" 2>/dev/null
fi
exec "$JAVA_HOME/bin/java" -jar "$MAVEN_WRAPPER_JAR" "$@"
